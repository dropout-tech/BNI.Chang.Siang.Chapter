# ============================================
# BNI 分會官網 — 環境變數設定
# ============================================
# 複製本檔案為 .env 並填入實際值
# cp .env.example .env

# Supabase（必填）
VITE_SUPABASE_URL=你的_Supabase_URL
VITE_SUPABASE_ANON_KEY=你的_Supabase_Anon_Key

# 分會認領密碼（必填 — 會員綁定帳號用）
VITE_CLAIM_PASSWORD=你的分會密碼

# Cloudflare Turnstile 防機器人（建議）
VITE_TURNSTILE_SITE_KEY=

# Google Analytics 4 (評估 ID)
VITE_GA_ID=

# Facebook Pixel ID（可選）
VITE_FB_PIXEL_ID=

# Microsoft Clarity Project ID（可選）
VITE_CLARITY_ID=
