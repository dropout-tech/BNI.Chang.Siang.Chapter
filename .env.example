# ============================================
# BNI 長翔名人堂白金分會 — 環境變數設定
# ============================================
# 複製本檔案為 .env 並填入實際值
# cp .env.example .env

# InsForge（必填 — Zeabur 原生綁定會自動注入）
VITE_INSFORGE_URL=https://your-app.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key
# OAuth / 驗證信回跳：請在 InsForge 後台將下列網址加入允許清單（含正式站與預覽網址）
#   {origin}{Vite base}login
#   {origin}{Vite base}member-edit?reset=true
# 例如 GitHub Pages：https://你的帳號.github.io/BNI.Chang.Siang.Chapter/login
# 自訂網域：https://changsiang.tw/BNI.Chang.Siang.Chapter/login（若 build 的 base 不同請一併調整）

# 分會認領密碼（必填 — 會員綁定帳號用）
VITE_CLAIM_PASSWORD=你的分會密碼

# Google Analytics 4 (評估 ID)
VITE_GA_ID=

# Facebook Pixel ID（可選）
VITE_FB_PIXEL_ID=

# Microsoft Clarity Project ID（可選）
VITE_CLARITY_ID=
